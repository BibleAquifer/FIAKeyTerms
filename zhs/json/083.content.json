[
  {
    "content_id": "871191",
    "reference_id": 186587,
    "version": "1.0.1",
    "title": "渔网",
    "media_type": "Text",
    "index_reference": "渔网",
    "language": "zhs",
    "review_level": "Professional",
    "content": "<p><strong>渔网</strong>是人们用来捕鱼的一种工具。人们把细绳编织在一起，做成一种布，这种布基本上就是很多小洞。渔民会把网扔进水中，然后在鱼游进网时把它拉回来。当渔民拉起渔网时，水会从渔网中流出，但鱼却无法从小孔中逃脱，它们就被捕获了。</p><p>你可以在可视化的圣经词典中查看渔网的图片。</p>",
    "associations": {
      "passage": [
        {
          "start_ref": "41001014",
          "start_ref_usfm": "MRK 1:14",
          "end_ref": "41001020",
          "end_ref_usfm": "MRK 1:20"
        },
        {
